---
import { Font } from "astro:assets";

// Static-only 404. Astro emits this as dist/404.html; nginx serves it via
// `error_page 404 /404.html`. Kept EN-only and self-contained — a static
// error page can't reliably resolve the visitor's locale.
const home = "/";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>404 — Page not found · Tom Girou</title>
    <meta name="robots" content="noindex,follow"/>
    <meta name="theme-color" content="#0A0A0A"/>
    <meta name="generator" content={Astro.generator}/>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
    <Font cssVariable="--display" preload/>
    <Font cssVariable="--mono" preload/>
</head>
<body>
<main class="nf">
    <p class="nf-code mono">404</p>
    <h1 class="nf-title">This page took a wrong turn.</h1>
    <p class="nf-lead">The URL you followed doesn't exist — it may have moved, or it was never here.</p>
    <a href={home} class="nf-cta">
        <span>Back to home</span>
        <span class="nf-arrow" aria-hidden="true">↗</span>
    </a>
</main>

<style is:global>
    :root {
        color-scheme: dark;
        --red: #E63A1F;
        --bg: #0A0A0A;
        --line-strong: rgba(255, 255, 255, .18);
        --ink: #EDEAE3;
        --ink-dim: #9A958B;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        -webkit-font-smoothing: antialiased;
    }

    body {
        background: var(--bg);
        color: var(--ink);
        font-family: var(--display);
        line-height: 1.4;
        min-height: 100dvh;
    }

    ::selection {
        background: var(--red);
        color: #fff;
    }

    a {
        color: inherit;
        text-decoration: none;
    }

    .nf {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 20px;
        padding: 40px 24px;
    }

    .nf-code {
        font-family: var(--mono);
        font-size: 14px;
        letter-spacing: .3em;
        color: var(--red);
    }

    .nf-title {
        font-weight: 800;
        font-size: clamp(30px, 6vw, 56px);
        line-height: 1.05;
        letter-spacing: -.02em;
        max-width: 14ch;
    }

    .nf-lead {
        color: var(--ink-dim);
        font-size: clamp(15px, 2.4vw, 18px);
        max-width: 42ch;
    }

    .nf-cta {
        margin-top: 12px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 13px 22px;
        font-size: 15px;
        border: 1.5px solid var(--line-strong);
        border-radius: 2px;
        transition: background .3s, color .3s, border-color .3s;
    }

    .nf-cta:hover {
        background: #fff;
        color: #0A0A0A;
        border-color: #fff;
    }

    .nf-arrow {
        transition: transform .35s cubic-bezier(.2, .7, .2, 1);
    }

    .nf-cta:hover .nf-arrow {
        transform: translate(3px, -3px);
    }
</style>
</body>
</html>
