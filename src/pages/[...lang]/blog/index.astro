---
import BlogLayout from "../../../layouts/BlogLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import AuthorCard from "../../../components/AuthorCard.astro";
import {
  defaultLocale,
  getTranslation,
  localeHtmlLang,
  locales,
  type Locale,
} from "../../../i18n";
import { blogPath, getPostsByLocale, parsePostId } from "../../../lib/blog";
import { buildBlogIndexGraph, type BlogPostMeta } from "../../../lib/schema";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { locale: "en" as const } },
    { params: { lang: "fr" }, props: { locale: "fr" as const } },
    { params: { lang: "es" }, props: { locale: "es" as const } },
  ];
}

const { locale } = Astro.props as { locale: Locale };
const t = getTranslation(locale);

const posts = await getPostsByLocale(locale);

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/og-image.jpg", Astro.site).href;
const rssHref = locale === defaultLocale ? "/rss.xml" : `/${locale}/rss.xml`;

const alternates = [
  ...locales.map((l) => ({
    hrefLang: localeHtmlLang[l],
    href: new URL(blogPath(l), Astro.site).href,
  })),
  { hrefLang: "x-default", href: new URL(blogPath(defaultLocale), Astro.site).href },
];

const langLinks = locales.map((l) => ({
  locale: l,
  href: blogPath(l),
  active: l === locale,
}));

const postsMeta: BlogPostMeta[] = posts.map((p) => {
  const { slug } = parsePostId(p.id);
  return {
    url: new URL(blogPath(locale, slug), Astro.site).href,
    title: p.data.title,
    description: p.data.description,
    datePublished: p.data.pubDate.toISOString().slice(0, 10),
    dateModified: p.data.updatedDate?.toISOString().slice(0, 10),
    tags: p.data.tags,
  };
});

const schemaJson = JSON.stringify(
  buildBlogIndexGraph(locale, t, canonical, ogImage, postsMeta),
);
---

<BlogLayout
  locale={locale}
  title={t.blog.metaTitle}
  description={t.blog.metaDescription}
  canonical={canonical}
  ogImage={ogImage}
  ogImageAlt={t.meta.ogImageAlt}
  ogType="website"
  alternates={alternates}
  langLinks={langLinks}
  schemaJson={schemaJson}
  rssHref={rssHref}
>
  <header class="blog-hero">
    <div class="wrap">
      <div class="mono blog-label">{t.blog.label}</div>
      <h1 set:html={t.blog.titleHtml}></h1>
      <p class="blog-blurb">{t.blog.blurb}</p>
      <div class="blog-author">
        <AuthorCard t={t} rssHref={rssHref} />
      </div>
    </div>
  </header>

  <section class="blog-list wrap">
    {posts.length === 0 ? (
      <p class="blog-empty">{t.blog.empty}</p>
    ) : (
      <ul class="post-grid">
        {posts.map((p) => <PostCard post={p} locale={locale} t={t} />)}
      </ul>
    )}
  </section>
</BlogLayout>

<style>
  .blog-hero {
    padding: 168px 0 56px;
    border-bottom: 1px solid var(--line);
  }

  .blog-label {
    margin-bottom: 22px;
  }

  .blog-hero h1 {
    font-family: var(--display);
    font-weight: 800;
    letter-spacing: -.03em;
    line-height: .98;
    font-size: clamp(44px, 7vw, 92px);
    text-wrap: balance;
  }

  .blog-blurb {
    margin-top: 26px;
    max-width: 60ch;
    color: var(--ink-dim);
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.6;
  }

  .blog-author {
    margin-top: 40px;
    max-width: 620px;
  }

  .blog-list {
    padding-top: 56px;
  }

  .blog-empty {
    color: var(--ink-dim);
    font-size: 18px;
  }

  .post-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 28px;
  }
</style>
